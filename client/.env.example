# Client environment variables
# These are set in Render dashboard → Static Site → Environment Variables

# Backend API URL (your Render Web Service URL)
VITE_API_URL=https://pocket-miner-api.onrender.com/api

# Backend WebSocket URL (same service, wss:// for HTTPS)
VITE_WS_URL=wss://pocket-miner-api.onrender.com/ws
