# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/pocket-miner?retryWrites=true&w=majority

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Mining Pool (VerusCoin example)
POOL_HOST=na.luckpool.net
POOL_PORT=3956
WALLET_ADDRESS=your_wallet_address_here
WORKER_NAME=pocketminer

# Reward Config
POOL_REWARD_RATE=0.0001
POINTS_PER_SHARE=10
SESSION_BONUS_MULTIPLIER=1.5
MIN_WITHDRAWAL=0.001

# Anti-Cheat
MAX_SHARES_PER_MINUTE=60
MAX_HASHRATE_MH=10

# CORS
CORS_ORIGIN=http://localhost:5173
